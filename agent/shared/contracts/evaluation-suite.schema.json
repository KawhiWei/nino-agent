{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nino-agent.local/schemas/evaluation-suite.schema.json",
  "title": "Nino Agent Skill Evaluation Suite",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "skill_id", "description", "derived_from", "cases"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9.-]+$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "skill_id": { "type": "string", "pattern": "^[a-z][a-z0-9.-]+$" },
    "description": { "type": "string", "minLength": 1 },
    "derived_from": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "category", "tags", "prompt", "derived_from", "expected"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9.-]+$" },
        "category": {
          "enum": ["scope", "clarification", "order-query", "aggregate", "anomaly", "boundary"]
        },
        "tags": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "prompt": { "type": "string", "minLength": 1 },
        "derived_from": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "expected": { "$ref": "#/$defs/expected" },
        "follow_ups": {
          "type": "array",
          "items": { "$ref": "#/$defs/followUp" },
          "default": []
        }
      }
    },
    "followUp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "relationship", "prompt", "derived_from", "expected"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9.-]+$" },
        "relationship": {
          "enum": ["related-history", "related-new-data", "unrelated-new-data", "unrelated-out-of-scope"]
        },
        "prompt": { "type": "string", "minLength": 1 },
        "derived_from": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "expected": { "$ref": "#/$defs/expected" }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "skill_id", "dispatch", "answer_facts"],
      "properties": {
        "status": { "enum": ["completed", "failed", "cancelled"] },
        "skill_id": { "type": ["string", "null"] },
        "dispatch": {
          "description": "Stable legacy name meaning that the request should enter the controlled business execution path. In Runtime 0.14 this requires a Planner proposal accepted by the Orchestrator, not Orchestrator-authored planning.",
          "type": "boolean"
        },
        "required_tools": {
          "type": "array", "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }, "default": []
        },
        "forbidden_tools": {
          "type": "array", "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }, "default": []
        },
        "required_references": {
          "type": "array", "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }, "default": []
        },
        "max_model_calls": { "type": "integer", "minimum": 0 },
        "expected_outcome": {
          "enum": ["normal", "clarification", "history_answer", "out_of_scope"]
        },
        "required_events": {
          "type": "array", "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }, "default": []
        },
        "forbidden_events": {
          "type": "array", "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }, "default": []
        },
        "required_model_phases": {
          "type": "array", "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }, "default": []
        },
        "forbidden_model_phases": {
          "type": "array", "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }, "default": []
        },
        "answer_facts": {
          "type": "array",
          "items": {
            "type": "array", "minItems": 1, "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
