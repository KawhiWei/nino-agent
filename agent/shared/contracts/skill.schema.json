{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nino-agent.local/schemas/skill.schema.json",
  "title": "Nino Agent Skill Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "instructions",
    "intent_keywords",
    "allowed_tools",
    "max_steps"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9.-]+$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "instructions": { "type": "string", "minLength": 1 },
    "intent_keywords": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "allowed_tools": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9_.-]+$" }
    },
    "capabilities": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "risk_level": {
      "enum": ["read-only", "write", "privileged"]
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "semantic_fallback": { "type": "boolean", "default": false }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "execution_shape": { "enum": ["adaptive", "single_node", "graph"] }
      }
    },
    "assurance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["best_effort", "strict_verify"] },
        "required_evaluators": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["verification", "review", "critique"] },
          "default": []
        }
      }
    },
    "loop": { "$ref": "#/$defs/loopBudget" },
    "max_steps": { "type": "integer", "minimum": 1, "maximum": 20 },
    "references": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9.-]+$" },
          "path": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evaluation_suites": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "is_default": { "type": "boolean", "default": false }
  },
  "$defs": {
    "loopBudget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_actions": { "type": "integer", "minimum": 1, "maximum": 100 },
        "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 3600 },
        "max_consecutive_failures": { "type": "integer", "minimum": 1, "maximum": 20 },
        "max_no_progress_steps": { "type": "integer", "minimum": 1, "maximum": 20 }
      }
    }
  }
}
