NINO_DB_PORT=55432
NINO_DB_CONNECTION_STRING=Host=localhost;Port=55432;Database=nino_data_demo;Username=nino;Password=nino_dev_password
NINO_DATA_MCP_PORT=8091
NINO_DATA_DB_CONNECTION_STRING=Host=localhost;Port=55432;Database=nino_data_demo;Username=nino_data_readonly;Password=nino_data_readonly_password
NINO_DATA_TEST_DB_CONNECTION_STRING=Host=localhost;Port=55432;Database=nino_data_demo;Username=nino_data_readonly;Password=nino_data_readonly_password
NINO_RUNTIME_MODE=demo
NINO_AGENT_ENGINE=lightweight
NINO_MODEL_ADAPTER=native
# The current Runtime model is fixed to gpt-5.4 in bootstrap.py.
OPENAI_API_KEY=
INCERRY_OPENAI_BASE_URL=http://core.dns-pro.net:13001/v1
# Optional OpenAI-compatible gateway controls. Leave empty unless the gateway requires them.
NINO_MODEL_THINKING=
NINO_MODEL_REASONING_EFFORT=
NINO_MCP_URL=http://127.0.0.1:8091/mcp
# JSON array for multi-MCP mode. Empty keeps the NINO_MCP_URL fallback.
NINO_MCP_SERVERS=
# Set to [frameworks] when building a Docker image that needs LangChain/LangGraph.
NINO_PIP_EXTRAS=
# Keep the official default. A cached Agent image can be used temporarily for offline rebuilding.
NINO_RUNTIME_BASE_IMAGE=python:3.12-slim
NINO_RUNTIME_PORT=8090
NINO_MAX_CONCURRENT_RUNS=4
NINO_STORAGE_PATH=./nino-agent-storage/nino-agent.db
NINO_MODEL_CONTEXT_TOKENS=128000
NINO_CONTEXT_RESERVED_TOKENS=32000
NINO_CONTEXT_RECENT_TOKENS=48000
NINO_CONTEXT_SUMMARY_TOKENS=12000
NINO_LOOP_HARD_MAX_STEPS=8
NINO_LOOP_HARD_MAX_ACTIONS=32
NINO_LOOP_HARD_TIMEOUT_SECONDS=300
NINO_LOOP_HARD_MAX_CONSECUTIVE_FAILURES=3
NINO_LOOP_HARD_MAX_NO_PROGRESS_STEPS=3
NINO_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# gpt-5.4 live profile (the model name is fixed in bootstrap.py):
# NINO_RUNTIME_MODE=live
# NINO_MODEL_ADAPTER=native
# OPENAI_API_KEY=<provided-through-the-process-environment>
# INCERRY_OPENAI_BASE_URL=http://core.dns-pro.net:13001/v1
